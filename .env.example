# Server Configuration
PORT=8080
NODE_ENV=development

# Core App Secrets
NEW_RELIC_APP_NAME=express-starter-app
NEW_RELIC_LICENSE_KEY=your_new_relic_license_key
APP_ENV=local
SWAGGER_ENABLED=true
CORS_ORIGINS=http://localhost:3000
CSRF_ENABLED=false
CSRF_SECRET=your_csrf_secret_here
REDIS_URL=redis://localhost:6379

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
MAIL_FROM=no-reply@example.com

# JWT Configuration
JWT_ACCESS_SECRET=your_access_secret_key
JWT_ACCESS_TTL=1h
JWT_REFRESH_TTL=7d
JWT_REFRESH_SECRET=your_refresh_secret_key

# Frontend Configuration
FRONTEND_URL=http://localhost:3000

# Security & Limits
RATE_LIMIT_ENABLED=true

# Database Configuration
# Format: postgresql://username:password@localhost:5432/dbname?schema=public
DATABASE_URL=postgresql://user:password@localhost:5432/db_name?schema=public

# AWS Configuration
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET_NAME=your_bucket_name
# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
PORT=8080
NODE_ENV=development
APP_ENV=local

# -----------------------------------------------------------------------------
# API Documentation
# -----------------------------------------------------------------------------
SWAGGER_ENABLED=true

# -----------------------------------------------------------------------------
# CORS
# Comma-separated list of allowed origins
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# -----------------------------------------------------------------------------
# CSRF Protection
# Generate using: openssl rand -hex 32
# -----------------------------------------------------------------------------
CSRF_ENABLED=true
CSRF_SECRET=your-32-byte-secret

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# New Relic
# -----------------------------------------------------------------------------
NEW_RELIC_APP_NAME=express-starter-app
NEW_RELIC_LICENSE_KEY=your-new-relic-license-key

# -----------------------------------------------------------------------------
# Build Information (Optional)
# Populated during CI/CD
# -----------------------------------------------------------------------------
GIT_COMMIT=abcdef123456
BUILD_TIME=2026-07-09T10:30:00Z